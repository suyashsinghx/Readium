<%- include("partials/header") %>

    <link rel="stylesheet" href="/stylesheets/global.css">
    <link rel="stylesheet" href="/stylesheets/public.css">
    <link
        href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,200..800;1,6..72,200..800&family=Inter:wght@300;400;500;600;700&display=swap"
        rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
        rel="stylesheet">

    <!-- ===== HERO ===== -->
    <section class="hero-section">
        <div class="hero-inner">

            <!-- HERO BG GLOW -->
            <div class="hero-glow" aria-hidden="true"></div>

            <div class="hero-content">
                <h1 class="hero-title">
                    Read to remember,<br>not just to finish.
                </h1>
                <p class="hero-sub">
                    Most people read and forget. Readium is the intentional sanctuary for your personal knowledge.
                </p>
                <div class="hero-actions">
                    <a href="/home" class="hero-btn-primary">Get Started</a>
                    <!-- <a href="#demo" class="hero-btn-ghost">View Demo</a> -->
                </div>
            </div>

        </div>
    </section>

    <!-- ===== EMOTIONAL HOOK ===== -->
    <section class="hook-section">
        <div class="hook-inner">

            <div class="hook-icon-wrap">
                <span class="material-symbols-outlined hook-icon">history_edu</span>
            </div>

            <blockquote class="hook-quote">
                "The average person forgets 70% of what they read within 24 hours."
            </blockquote>

            <div class="hook-divider" aria-hidden="true"></div>

            <p class="hook-sub">YOUR BOOKS DESERVE BETTER THAN A LEAKY MIND.</p>

        </div>
    </section>

    <!-- ===== TRANSFORMATION ===== -->
    <section class="transform-section">
        <div class="transform-inner">

            <!-- LEFT: IMAGE + FLOATING CARD -->
            <div class="transform-left">
                <div class="transform-img-wrap">
                    <img src="https://images.unsplash.com/photo-1544947950-fa07a98d237f?q=80&w=1287&auto=format&fit=crop"
                        alt="Premium edition of Meditations by Marcus Aurelius" class="transform-img">
                    <!-- FLOATING INSIGHT CARD -->
                    <div class="transform-float-card">
                        <p class="transform-float-quote">"The soul becomes dyed with the color of its thoughts."</p>
                        <span class="transform-float-label">Insight #12</span>
                    </div>
                </div>
            </div>

            <!-- RIGHT: TEXT -->
            <div class="transform-right">
                <div class="transform-text-block">
                    <h3 class="transform-title">From ephemeral pages to eternal insights.</h3>
                    <p class="transform-body">
                        Readium captures the essence of your reading. It doesn't just store text; it distills meaning.
                        We turn your highlights into a living, breathing network of ideas.
                    </p>
                </div>

                <div class="transform-features">

                    <div class="transform-feature">
                        <div class="transform-feature-icon transform-feature-icon--blue">
                            <span class="material-symbols-outlined">auto_fix_high</span>
                        </div>
                        <div class="transform-feature-text">
                            <h4 class="transform-feature-title">Organic Distillation</h4>
                            <p class="transform-feature-body">Our AI doesn't just summarize; it identifies the core
                                philosophical weight of your highlights.</p>
                        </div>
                    </div>

                    <div class="transform-feature">
                        <div class="transform-feature-icon transform-feature-icon--green">
                            <span class="material-symbols-outlined">psychology</span>
                        </div>
                        <div class="transform-feature-text">
                            <h4 class="transform-feature-title">Spaced Reflection</h4>
                            <p class="transform-feature-body">Quiet notifications invite you back to your most important
                                thoughts at the perfect biological interval.</p>
                        </div>
                    </div>

                </div>
            </div>

        </div>
    </section>

    <!-- ===== PERSONAL ARCHIVE PREVIEW ===== -->
    <section class="archive-section">
        <div class="archive-inner">

            <!-- LEFT: ARCHIVE UI CARD -->
            <div class="archive-ui-wrap">
                <div class="archive-ui-card">

                    <div class="archive-card-header">
                        <h5 class="archive-card-title">Personal Archive</h5>
                        <span class="material-symbols-outlined archive-card-more">more_vert</span>
                    </div>

                    <!-- BOOK ROW -->
                    <div class="archive-book-row">
                        <div class="archive-book-cover">
                            <img src="https://images.unsplash.com/photo-1589829085413-56de8ae18c73?q=80&w=1224&auto=format&fit=crop"
                                alt="Book cover" class="archive-book-img">
                        </div>
                        <div class="archive-book-meta">
                            <h6 class="archive-book-title">The Creative Act</h6>
                            <p class="archive-book-author">Rick Rubin</p>
                            <div class="archive-book-tags">
                                <span class="archive-tag">24 Reflections</span>
                            </div>
                        </div>
                    </div>

                    <div class="archive-divider" aria-hidden="true"></div>

                    <!-- AI DISTILLATION BLOCK -->
                    <div class="archive-ai-block">
                        <div class="archive-ai-label-row">
                            <span class="material-symbols-outlined archive-ai-star">auto_awesome</span>
                            <span class="archive-ai-label">AI Distillation</span>
                        </div>
                        <p class="archive-ai-quote">
                            "Art is not a goal, but a way of being. Your archive should not be a trophy case, but the
                            soil for your next creation."
                        </p>
                    </div>

                </div>
            </div>

            <!-- RIGHT: TEXT -->
            <div class="archive-text">
                <h2 class="archive-title">A static interface for<br>dynamic thinking.</h2>
                <p class="archive-body">
                    Readium's interface is designed to disappear. We use tonal layering and soft shadows to create a
                    workspace that feels as calm as a physical library at dawn.
                </p>
                <ul class="archive-list">
                    <li class="archive-list-item">
                        <span class="archive-bullet" aria-hidden="true"></span>
                        No distracting UI elements
                    </li>
                    <li class="archive-list-item">
                        <span class="archive-bullet" aria-hidden="true"></span>
                        Typographic-first hierarchy
                    </li>
                    <li class="archive-list-item">
                        <span class="archive-bullet" aria-hidden="true"></span>
                        Deep-work native focus modes
                    </li>
                </ul>
            </div>

        </div>
    </section>

    <!-- ===== MANIFESTO ===== -->
    <section class="manifesto-section">
        <div class="manifesto-inner">

            <div class="manifesto-eyebrow-wrap">
                <span class="manifesto-eyebrow">OUR MANIFESTO</span>
            </div>

            <h2 class="manifesto-title">No streaks. No metrics.<br>Just depth.</h2>

            <p class="manifesto-body">
                Knowledge isn't a game to be won, but a garden to be tended. In a world obsessed with 'quantity read',
                Readium celebrates the depth of a single paragraph. We don't track your reading speed. We track your
                resonance.
            </p>

            <div class="manifesto-rule" aria-hidden="true"></div>

        </div>
    </section>

    <!-- ===== FINAL CTA ===== -->
    <section class="cta-section">
        <div class="cta-inner">
            <div class="cta-card">
                <div class="cta-glow" aria-hidden="true"></div>
                <div class="cta-content">
                    <h2 class="cta-title">Your second brain is<br>waiting to be built.</h2>
                    <div class="cta-actions">
                        <a href="/home" class="cta-btn">Start Building Your Knowledge System</a>
                    </div>
                    <p class="cta-footnote">Enter a library of 12,000+ titles, curated for deep readers.</p>
                </div>
            </div>
        </div>
    </section>

    <%- include("partials/footer") %>