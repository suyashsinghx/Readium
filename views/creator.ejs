<%- include("partials/header") %>

    <link rel="stylesheet" href="/stylesheets/global.css">
    <link rel="stylesheet" href="/stylesheets/creator.css">
    <link
        href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,200..800;1,6..72,200..800&family=Inter:wght@100..900&display=swap"
        rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
        rel="stylesheet">

    <main class="atelier-main">

        <!-- ===== HERO: MEET THE CREATOR ===== -->
        <section class="hero-section">

            <!-- LEFT -->
            <div class="hero-left">
                <span class="hero-eyebrow">THE ARCHITECT</span>
                <h1 class="hero-title">
                    Meet the <span class="hero-title-light">Creator</span>
                </h1>
                <p class="hero-body">
                I design for clarity over noise.
                <br>
                Readium reflects how I think —
                focused, intentional, and built for people who want more from what they read.
                </p>
            </div>

            <!-- RIGHT -->
            <div class="hero-right">
                <div class="hero-image-wrap">
                    <img src="/images/suyash ID upload.png"
                        alt="Portrait of the developer" class="hero-img" />
                </div>
                <div class="hero-quote-card">
                    <p class="hero-quote-text">"Complexity is easy. Quietude is the ultimate engineering challenge."</p>
                </div>
            </div>

        </section>

        <!-- ===== PHILOSOPHY ===== -->
        <section class="philosophy-section">

            <div class="philosophy-grid">

                <!-- LEFT CARD -->
                <div class="philosophy-card">
                    <h2 class="philosophy-card-title">Philosophy</h2>
                    <p class="philosophy-card-body">
                        We are drowning in data but starving for wisdom. My work focuses on curation over consumption
                        and depth over speed.
                    </p>
                    <div class="philosophy-items">

                        <div class="philosophy-item">
                            <span class="material-symbols-outlined phil-icon">auto_stories</span>
                            <div class="phil-item-text">
                                <p class="phil-item-title">Intentionality</p>
                                <p class="phil-item-sub">Every interaction is a choice.</p>
                            </div>
                        </div>

                        <div class="philosophy-item">
                            <span class="material-symbols-outlined phil-icon">psychology</span>
                            <div class="phil-item-text">
                                <p class="phil-item-title">Deep Work</p>
                                <p class="phil-item-sub">Creating space for the cognitive flow.</p>
                            </div>
                        </div>

                    </div>
                </div>

                <!-- RIGHT CONTENT -->
                <div class="philosophy-right">
                    <h3 class="philosophy-right-title">Curating the Digital Life.</h3>
                    <div class="philosophy-blockquote">
                        <p class="philosophy-quote-text">
                            "Readium is more than a book tracker.
                            It helps you store insights, revisit ideas, and turn reading into something that compounds over time."
                        </p>
                    </div>
                </div>

            </div>
        </section>

        <!-- ===== STACK & PRINCIPLES ===== -->
        <section class="stack-section">

            <h2 class="stack-title">Stack &amp; Principles</h2>

            <div class="stack-grid">

                <!-- Node.js — spans 2 cols -->
                <div class="stack-card stack-card--wide">
                    <div class="stack-card-top">
                        <span class="stack-label">RUNTIME</span>
                        <h4 class="stack-card-title">Node.js &amp; Express</h4>
                    </div>
                    <p class="stack-card-body">The backbone of asynchronous efficiency, providing the speed necessary
                        for real-time thought capturing.</p>
                </div>

                <!-- PostgreSQL -->
                <div class="stack-card stack-card--white">
                    <div class="stack-card-top">
                        <span class="stack-label">PERSISTENCE</span>
                        <h4 class="stack-card-title">PostgreSQL</h4>
                    </div>
                    <p class="stack-card-body">Relational integrity for interconnected ideas.</p>
                </div>

                <!-- EJS -->
                <div class="stack-card stack-card--mid">
                    <div class="stack-card-top">
                        <span class="stack-label">VIEW ENGINE</span>
                        <h4 class="stack-card-title">EJS</h4>
                    </div>
                    <p class="stack-card-body">Lightweight templating that honors the simplicity of HTML.</p>
                </div>

                <!-- Minimalist Readability — spans 3 cols -->
                <div class="stack-card stack-card--wide3">
                    <div class="stack-readability-inner">
                        <div class="stack-readability-text">
                            <h4 class="stack-readability-title">Minimalist Readability</h4>
                            <p class="stack-card-body">Design should vanish. My principles focus on generous whitespace
                                and high typographic contrast to ensure that the user's content is always the hero.</p>
                        </div>
                        <span class="material-symbols-outlined stack-quote-icon">format_quote</span>
                    </div>
                </div>

                <!-- Dark Mode / Optics First -->
                <div class="stack-card stack-card--dark">
                    <span class="material-symbols-outlined stack-dark-icon">dark_mode</span>
                    <p class="stack-dark-label">OPTICS FIRST</p>
                </div>

            </div>
        </section>

        <!-- ===== CONNECT ===== -->
        <section class="connect-section">

            <h2 class="connect-title">Let's build something intentional.</h2>

            <div class="connect-links">
                <a href="https://github.com/suyashsinghx" target="_blank" class="connect-link">
                    <span class="material-symbols-outlined connect-link-icon">code</span>
                    <span class="connect-link-label">GitHub</span>
                </a>
                <a href="https://www.linkedin.com/in/suyashsingh04/" target="_blank" class="connect-link">
                    <span class="material-symbols-outlined connect-link-icon">link</span>
                    <span class="connect-link-label">LinkedIn</span>
                </a>
                <a href="mailto:suyashsinghx@gmail.com" target="_blank" class="connect-link">
                    <span class="material-symbols-outlined connect-link-icon">mail</span>
                    <span class="connect-link-label">Contact</span>
                </a>
                <a href="https://www.instagram.com/suyashsinghx" target="_blank" class="connect-link">
                    <!-- <span class="material-symbols-outlined connect-link-icon">palette</span> -->
                    <i class="ri-instagram-line connect-link-icon"></i>
                    <span class="connect-link-label ">Instagram</span>
                </a>
            </div>

            <div class="connect-cta-wrap">
            <a href="mailto:your@email.com" target="_blank" class="connect-cta-btn">GET IN TOUCH</a>
            </div>

        </section>

    </main>

    <%- include("partials/footer") %>