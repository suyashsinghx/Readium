

    <link rel="stylesheet" href="/stylesheets/global.css">
    <link rel="stylesheet" href="/stylesheets/signup.css">
    <link
        href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,200..800;1,6..72,200..800&family=Inter:wght@300;400;500;600;700&display=swap"
        rel="stylesheet">

    <!-- DECORATIVE BACKGROUND BLOBS -->
    <div class="bg-blob bg-blob--right" aria-hidden="true"></div>
    <div class="bg-blob bg-blob--left" aria-hidden="true"></div>

    <main class="signup-main">
        <div class="signup-wrapper">

            <!-- PAGE HEADING -->
            <div class="signup-heading">
                <h2 class="signup-heading-title">Curate your mind.</h2>
                <p class="signup-heading-sub">Join a sanctuary designed for intentional thought and focused inquiry.</p>
            </div>

            <!-- FORM CARD -->
            <div class="signup-card">
                <form action="/auth/signup" method="POST" class="signup-form">

                    <!-- FULL NAME -->
                    <div class="form-field">
                        <label for="full_name" class="field-label">Full Name</label>
                        <input type="text" id="full_name" name="name" placeholder="Elias Thorne" required
                            class="field-input" />
                    </div>

                    <!-- EMAIL -->
                    <div class="form-field">
                        <label for="email" class="field-label">Email</label>
                        <input type="email" id="email" name="email" placeholder="curator@readium.com" required
                            class="field-input" />
                    </div>

                    <!-- PASSWORD -->
                    <div class="form-field">
                        <label for="password" class="field-label">Password</label>
                        <input type="password" id="password" name="password" placeholder="••••••••" required
                            class="field-input" autocomplete="off"/>
                    </div>

                    <!-- TERMS -->
                    <!-- <div class="form-terms">
                        <div class="terms-checkbox-wrap">
                            <input type="checkbox" id="terms" name="terms" required class="terms-checkbox">
                        </div>
                        <label for="terms" class="terms-label">
                            I accept the <a href="#" class="terms-link">Manifesto</a> and acknowledge the <a href="#"
                                class="terms-link">Privacy</a> guidelines.
                        </label>
                    </div> -->

                    <!-- SUBMIT -->
                    <!-- SUBMIT -->
                    <button type="submit" class="google-btn">
                        <img src="/images/favicon.ico/favicon.svg" alt="Google" class="google-icon" style="height: 18px;">
                        <span>Signup</span>
                    </button>

                    <div class="signup-divider">
                        <span>OR</span>
                    </div>
                    
                    <a href="/auth/google" class="google-btn">
                        <img src="https://www.svgrepo.com/show/475656/google-color.svg" alt="Google" class="google-icon" style="height: 18px;">
                        <!-- <i class="ri-google-fill"></i> -->
                        <span>Sign up with Google</span>
                    </a>

                </form>

                <!-- LOGIN LINK -->
                <div class="signup-login-row">
                    <p class="signup-login-text">
                        Already part of the Readium?
                        <a href="/auth/login" class="signup-login-link">Log in here</a>
                    </p>
                </div>

            </div>

            <div class="login-below-card">
            
                <!-- DECORATIVE BOOK IMAGE (bottom-left) -->
                <div class="login-deco-img-wrap">
                    <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuBEz-mcT1iC4AR0Ht1bUfjmw_n5SevGrtxIznjcOAgvkFi4puElUV_hGQNlHQYkbhfRKgG61IwXO84IPW7CrUeUkW9rdDPV7QF0KPZjX26Y8g0J5CFwvo3GXH0FtcBRW9Y83lkNFdD1hMcD84AjZTpVlKwZJ-IKWb1RE1QZ9tYVmI3QkOr63QfQd9eVwgyhk2iRZvLIxPrKhT5BcAroQiqUyVct82brl_FvtRL-zwm4BskzhEq83WKFLHDTCGCsamGm_Eb8qk6rrtE"
                        alt="Books on a linen surface" class="login-deco-img" />
                </div>

                <!-- MANIFESTO QUOTE BLOCK -->
                <div class="signup-quote-block">
                    <p class="signup-quote-text">
                        "Readium is not a tool for productivity, but a vessel for presence. Here, we trade noise
                        for nuance."
                    </p>
                    <span class="signup-quote-source">FROM THE MANIFESTO</span>
                </div>

            </div>

            

        </div>
    </main>

